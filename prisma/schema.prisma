generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ===== SABI USER MODELS =====

model SabiUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   // Optional if using OAuth
  name          String
  businessName  String?   // If reseller
  phone         String?
  country       String    @default("NG")

  // Email verification
  emailVerified Boolean   @default(false)
  verifyCode    String?
  verifyCodeExpiry DateTime?

  // OAuth integration
  googleId      String?   @unique

  // Profile
  avatarUrl     String?
  referralCode  String?   @unique // For partner referrals
  referredByCode String?  // Who referred this user

  // Session
  sessionToken  String?   // Hashed
  sessionExpiry DateTime?

  // Account status
  status        String    @default("active") // active, suspended, banned
  apiKeyHash    String?   // For API access
  apiKeyCreatedAt DateTime?

  // Preferences
  webhookUrl    String?   // For API order callbacks
  notifyEmail   Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  orders        SabiOrder[]
  wallet        SabiWallet?
  apiTokens     SabiApiToken[]
  transactions  SabiTransaction[]

  @@index([email])
  @@index([status])
  @@index([referralCode])
}

model SabiWallet {
  id            String    @id @default(cuid())
  userId        String    @unique
  balance       Int       @default(0)        // kobo (NGN)
  totalFunded   Int       @default(0)
  totalSpent    Int       @default(0)
  totalRefunded Int       @default(0)
  updatedAt     DateTime  @updatedAt

  // Relationships
  user          SabiUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SabiOrder {
  id                    String    @id @default(cuid())
  userId                String

  // Order details
  serviceType           String    // 'followers', 'likes', 'comments', 'shares', 'views', 'engagement'
  targetUrl             String
  quantity              Int

  // Pricing (in kobo)
  pricePerUnit          Int
  totalPrice            Int
  platformFee           Int       // 15% of totalPrice

  // Payment
  paymentMethod         String    @default("flutterwave") // flutterwave, wallet
  transactionRef        String?   // Flutterwave txRef

  // Execution
  status                String    @default("pending") // pending, processing, executing, completed, failed, cancelled
  gamesz360CampaignId   String?   // FK to ads.gamerz360.com Campaign
  gamesz360AdvertiserId String?   // Internal advertiser created for this order

  // Progress tracking
  completedQuantity     Int       @default(0)
  completionPercentage  Int       @default(0)
  estimatedCompletion   DateTime?

  // Metadata
  orderedVia            String    @default("web") // web, api, sms, etc.
  clientId              String?   // For API orders, track which reseller placed it
  customRef             String?   // Customer's reference code

  // Refund
  refundedAmount        Int       @default(0)
  refundReason          String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  completedAt           DateTime?

  // Relationships
  user                  SabiUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([gamesz360CampaignId])
  @@index([serviceType])
  @@index([createdAt])
}

model SabiTransaction {
  id            String    @id @default(cuid())
  userId        String
  orderId       String?   // Optional, links to order

  type          String    // 'fund_pending', 'fund', 'spend', 'refund', 'bonus'
  amount        Int       // kobo
  reference     String?   // Flutterwave txRef or internal reference
  description   String?

  createdAt     DateTime  @default(now())

  // Relationships
  user          SabiUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model SabiApiToken {
  id            String    @id @default(cuid())
  userId        String

  name          String    // e.g., "Mobile App", "Dashboard Integration"
  tokenHash     String    // SHA256(token)
  lastUsedAt    DateTime?
  expiresAt     DateTime?

  createdAt     DateTime  @default(now())

  // Relationships
  user          SabiUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== NEXTAUTH MODELS =====

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== RESELLER PROGRAM MODELS =====

model Reseller {
  id                String    @id @default(cuid())

  // Business info
  businessName      String
  businessEmail     String    @unique
  businessPhone     String
  businessAddress   String?
  country           String    @default("NG")

  // Contact person
  contactName       String
  contactEmail      String
  contactPhone      String

  // Account status
  status            String    @default("pending")  // pending, approved, active, suspended, rejected
  approvalDate      DateTime?
  rejectionReason   String?

  // Billing
  paymentMethod     String?   // bank_transfer, wallet
  accountNumber     String?
  bankCode          String?

  // Dates
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  sites             ResellerSite[]
  billing           ResellerBilling[]
  supportTickets    SupportTicket[]

  @@index([status])
  @@index([businessEmail])
}

model ResellerSite {
  id                String    @id @default(cuid())
  resellerId        String

  // Site info
  siteName          String
  siteUrl           String?   @unique
  customDomain      String?   @unique

  // Branding
  logoUrl           String?
  primaryColor      String    @default("#3B82F6")
  secondaryColor    String    @default("#8B5CF6")
  accentColor       String    @default("#EC4899")

  // Customization
  heroTitle         String    @default("Real Social Media Engagement")
  heroSubtitle      String    @default("Powered by Nigerian Users")
  aboutSection      String?   // Custom HTML/markdown
  featuresCustom    String?   // JSON array of custom features

  // Status
  status            String    @default("building")  // building, ready, live, suspended
  launchedAt        DateTime?

  // API
  apiKey            String    @unique @default(cuid())
  apiKeyCreatedAt   DateTime  @default(now())

  // Analytics
  totalOrders       Int       @default(0)
  totalRevenue      Int       @default(0)  // kobo

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  reseller          Reseller  @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  orders            ResellerOrder[]

  @@index([resellerId])
  @@index([status])
}

model ResellerOrder {
  id                String    @id @default(cuid())
  siteId            String

  // Order details (mirrors main order but tracks reseller)
  serviceType       String
  targetUrl         String
  quantity          Int

  // Pricing
  pricePerUnit      Int       // kobo
  totalPrice        Int       // kobo
  platformFee       Int

  // Reseller revenue
  resellerRevenue   Int       // kobo (what reseller keeps)
  sabiRevenue       Int       // kobo (what Sabi keeps from markup)

  // Payment
  paymentMethod     String    @default("flutterwave")
  transactionRef    String?

  // Status
  status            String    @default("pending")
  completedAt       DateTime?

  createdAt         DateTime  @default(now())

  // Relationships
  site              ResellerSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([status])
}

model ResellerBilling {
  id                String    @id @default(cuid())
  resellerId        String

  // Billing period
  billingMonth      DateTime  // First day of billing month

  // Charges
  setupFee          Int       @default(5000000)  // N50,000 in kobo (one-time on first month)
  maintenanceFee    Int       @default(1000000)  // N10,000/month in kobo
  orderCommission   Int       @default(0)        // Commission from orders (calculated)

  totalAmount       Int       // Total due for month
  amountPaid        Int       @default(0)

  // Status
  status            String    @default("pending")  // pending, paid, overdue
  dueDate           DateTime
  paidDate          DateTime?

  // Invoice
  invoiceNumber     String?   @unique
  invoiceUrl        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  reseller          Reseller  @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([status])
  @@index([billingMonth])
}

model SupportTicket {
  id                String    @id @default(cuid())
  resellerId        String

  // Ticket info
  subject           String
  description       String
  priority          String    @default("medium")  // low, medium, high, urgent

  // Status
  status            String    @default("open")  // open, in_progress, resolved, closed

  // Tracking
  assignedTo        String?
  resolvedAt        DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  reseller          Reseller  @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([status])
}
